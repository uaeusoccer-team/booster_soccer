<!-- Cam find and track ball -->

<root BTCPP_format="4" >
  <BehaviorTree ID="CamFindAndTrackBall">
     <Sequence name="root">
         <IfThenElse>
             <ScriptCondition        name="Ball visible or location known?" code="ball_detected || ball_location_known || tm_ball_pos_reliable" />
             <Sequence               name="[Yes] -> Track ball and adjust position" >
                <CamTrackBall />
             </Sequence>
             <Sequence               name="[No] -> Find ball">
                <CamFindBall />
             </Sequence>
         </IfThenElse>
     </Sequence>
  </BehaviorTree>
</root>
